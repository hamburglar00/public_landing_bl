# Supabase (landing pública)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Revalidación: mismo valor que en el constructor (Configuración → Revalidate secret)
REVALIDATE_SECRET=

# CORS: orígenes que pueden llamar a /api/revalidate (constructor). Varios separados por coma.
# Local: http://localhost:3001
# Producción: https://tu-constructor.vercel.app
ALLOWED_ORIGINS=
